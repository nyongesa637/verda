# Wakili — example environment.
# Copy to `.env` and `source .env` (or export manually) before running
# `make backend` / `make frontend`. Anything left unset uses the defaults
# documented in docs/AUTH.md.

# -- Auth (REQUIRED — Wakili authenticates by default) ---------------------
# Both flags ON. Wakili requires sign-in. Setting these to `false` to allow
# anonymous access is supported only for offline / air-gapped CI runs.
WAKILI_AUTH_ENABLED=true
NEXT_PUBLIC_WAKILI_AUTH_ENABLED=true

# Keycloak (matches infra/docker-compose.keycloak.yml + the imported realm)
WAKILI_KEYCLOAK_ISSUER=http://localhost:8080/realms/wakili
WAKILI_KEYCLOAK_CLIENT_ID=wakili-frontend
WAKILI_KEYCLOAK_AUDIENCE=wakili-frontend
KEYCLOAK_CLIENT_SECRET=wakili-dev-secret

# Frontend self-URL (used to build the OAuth redirect URI). MUST match the
# redirectUris registered in Keycloak.
WAKILI_APP_URL=http://localhost:3000

# Where the frontend's server-side fetch calls reach the backend.
WAKILI_INTERNAL_API_BASE=http://127.0.0.1:8765

# -- Demo / test credentials (provisioned in the bundled realm) ------------
# Use these on the /sign-in page after `make stack`.
#   advocate     / advocate     (role: lawyer)
#   paralegal    / paralegal    (role: paralegal)
#   nimrod   / nimrod   (role: admin)
WAKILI_DEMO_USER=advocate
WAKILI_DEMO_PASSWORD=advocate

# -- Optional OpenAI for petition polish (no raw evidence is ever sent) ----
# OPENAI_API_KEY=
# WAKILI_OPENAI_MODEL=gpt-4o-mini

# -- CORS for the API (comma-separated origins) ----------------------------
# WAKILI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
